# Copy to `.env` and fill in the key for whichever provider you select in config.
# Then set ai.provider in config/default.json (or ~/.freelycluely/config.json).

# Anthropic (Claude) — ai.provider = "anthropic"
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o) — ai.provider = "openai"
OPENAI_API_KEY=

# Google Gemini — ai.provider = "gemini"
GEMINI_API_KEY=

# Optional: override the local whisper model used by `npm run whisper:setup`
# WHISPER_MODEL=base.en
